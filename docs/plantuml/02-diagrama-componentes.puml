@startuml
title FoodStack - Arquitetura AWS (Completa)

skinparam shadowing false
skinparam componentStyle uml2
skinparam packageStyle rectangle
skinparam defaultFontName Arial
skinparam ArrowColor Black
skinparam linetype polyline
skinparam component {
  BackgroundColor White
  BorderColor Black
}
skinparam rectangle {
  BackgroundColor White
  BorderColor Black
}
skinparam database {
  BackgroundColor White
  BorderColor Black
}
skinparam queue {
  BackgroundColor White
  BorderColor Black
}

component "Portal Web" as PortalWeb

together {
  () "Dashboard API" as IDashboard
  () "Despensa API" as IDespensa
  () "Login/Token" as IAuth
  () "Receitas API" as IReceitas
  () "Sugestões API" as ISugestoes
  () "Compras API" as ICompras
}

PortalWeb ..> IDashboard
PortalWeb ..> IDespensa
PortalWeb ..> IAuth
PortalWeb ..> IReceitas
PortalWeb ..> ISugestoes
PortalWeb ..> ICompras

rectangle "Backend (AWS Cloud)" as Backend {
  component "Dashboard\nService" as Dashboard
  component "Módulo de\nDespensa" as Pantry
  component "Auth Service\n(AWS Cognito)" as Auth
  component "Módulo de\nReceitas" as Recipe
  component "Motor de\nSugestão" as Suggestion
  component "Módulo de\nCompras" as Shopping
  component "Módulo de\nNotificações" as Notification
}

IDashboard -- Dashboard
IDespensa -- Pantry
IAuth -- Auth
IReceitas -- Recipe
ISugestoes -- Suggestion
ICompras -- Shopping

() "Evento\nValidade" as ExpirationEvent
() "Evento\nPreparo" as PreparedEvent
() "Score\nReceita" as RecipeScore
() "Lista\nCompras" as ShoppingList
() "Dados\nNutricionais" as NutritionData

rectangle "Infraestrutura AWS" as Infra {
  queue "Fila de Eventos\n(Amazon SQS)" as SQS
  component "Envio de E-mails\n(Amazon SES)" as SES
  database "PostgreSQL\n(Amazon RDS)" as RDS
  database "Cache de Ranking\n(Amazon ElastiCache)" as Redis
  component "Arquivos/Imagens\n(Amazon S3)" as S3
}

rectangle "Serviços Externos" as Externos {
  component "OpenFoodFacts" as OpenFoodFacts
  component "Firebase Push" as Firebase
}

Backend -[hidden]down- Infra
Infra -[hidden]right- Externos
PreparedEvent -[hidden]right- ExpirationEvent
ExpirationEvent -[hidden]right- RecipeScore
RecipeScore -[hidden]right- ShoppingList
ShoppingList -[hidden]right- NutritionData

Pantry ..> ExpirationEvent : publica
Pantry ..> PreparedEvent : publica baixa
Suggestion ..> RecipeScore : calcula
Shopping ..> ShoppingList : gera
Recipe ..> NutritionData : consulta

ExpirationEvent --> SQS
PreparedEvent --> SQS
Notification --> SQS : consome
Notification --> SES : envia alertas
Notification --> Firebase : envia push

Dashboard --> RDS
Auth --> RDS
Pantry --> RDS
Recipe --> RDS
Suggestion --> RDS
Shopping --> RDS
Suggestion --> Redis : ranking
Recipe --> S3 : upload/leitura
NutritionData --> OpenFoodFacts

note left of Backend
  Componentes planejados para uma
  API Spring Boot modular.
end note
@enduml
