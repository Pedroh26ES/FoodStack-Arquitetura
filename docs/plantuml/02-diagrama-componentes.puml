@startuml
title FoodStack - Diagrama de Componentes: Arquitetura da Solução

skinparam shadowing false
skinparam componentStyle uml2
skinparam packageStyle rectangle
skinparam defaultFontName Arial
skinparam ArrowColor Black
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 55
skinparam component {
  BackgroundColor White
  BorderColor Black
}
skinparam rectangle {
  BackgroundColor White
  BorderColor Black
}
skinparam database {
  BackgroundColor White
  BorderColor Black
}
skinparam queue {
  BackgroundColor White
  BorderColor Black
}

top to bottom direction

rectangle "Canais de Acesso" as Canais {
  component "Portal Web\nReact + Vite" as PortalWeb
  component "App Mobile\nFuturo" as AppMobile
}

component "API Gateway\nREST/JSON + JWT\n\n/auth\n/despensas\n/receitas\n/sugestoes\n/compras\n/familia\n/dashboard" as Gateway

rectangle "Backend (AWS Cloud)\nAPI Spring Boot modular" as Backend {
  rectangle "Segurança e gestão" as SegurancaGestao {
    component "Auth Service\nAWS Cognito\n- autenticação\n- sessão\n- permissões" as Auth
    component "Compartilhamento Service\n- membros\n- convites\n- papéis" as Sharing
    component "Dashboard Service\n- indicadores\n- métricas de uso" as Dashboard
  }

  rectangle "Domínio FoodStack" as Dominio {
    component "Despensa Service\n- estoque\n- validade\n- armazenamento" as Pantry
    component "Receitas Service\n- catálogo\n- receitas próprias\n- favoritos" as Recipe
    component "Sugestão Engine\n- compatibilidade\n- vencimento\n- restrições" as Suggestion
    component "Compras Service\n- faltantes\n- lista de compras" as Shopping
  }

  rectangle "Suporte operacional" as Suporte {
    component "Notificação Service\n- alertas\n- eventos\n- lembretes" as Notification
    component "Auditoria Service\n- histórico\n- rastreabilidade" as Audit
  }
}

rectangle "Infraestrutura AWS" as Infra {
  database "PostgreSQL\nAmazon RDS\nDados transacionais" as RDS
  database "Redis\nElastiCache\nRanking/cache" as Redis
  queue "Amazon SQS\nEventos de domínio" as SQS
  component "Amazon SES\nE-mail" as SES
  component "Amazon S3\nImagens/anexos" as S3
  component "CloudWatch\nLogs/métricas" as CloudWatch
}

rectangle "Serviços Externos" as Externos {
  component "Firebase Cloud Messaging\nPush notification" as Firebase
  component "OpenFoodFacts API\nDados nutricionais" as FoodFacts
}

SegurancaGestao -[hidden]down-> Dominio
Dominio -[hidden]down-> Suporte

PortalWeb --> Gateway : HTTPS
AppMobile --> Gateway : HTTPS
Gateway --> Backend : roteamento REST

Suggestion ..> Pantry : consulta estoque
Suggestion ..> Recipe : consulta receitas
Shopping ..> Pantry : calcula saldo
Shopping ..> Recipe : lê ingredientes
Sharing ..> Auth : valida identidade
Audit ..> Pantry : registra movimentações
Notification ..> Pantry : acompanha validade

Backend -down-> Infra : usa serviços AWS
Backend -down.> Externos : integrações externas

Infra -[hidden]right-> Externos

note right of Gateway
  O gateway centraliza os contratos HTTP.
  Cada rota é atendida por um módulo do backend.
end note

legend left
  |= Elemento |= Papel no diagrama |
  | Componente | Unidade lógica implantável ou módulo da API |
  | Dependência tracejada | Colaboração entre módulos |
  | Dependência contínua | Integração técnica ou uso de infraestrutura |
  | AWS/Externos | Serviços consumidos pela aplicação |
  | Escopo | Projeto arquitetural, sem implementação obrigatória |
endlegend
@enduml
